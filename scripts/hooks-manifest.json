{
  "claude": {
    "target": "~/.claude/settings.json",
    "format": "claude",
    "events": {
      "SessionStart": ["start"],
      "SessionEnd": ["end"],
      "UserPromptSubmit": ["working"],
      "PostToolUse": ["working"],
      "PostToolUseFailure": ["working"],
      "PostToolBatch": ["working"],
      "SubagentStart": ["working"],
      "PreToolUse": [{ "matcher": "AskUserQuestion|ExitPlanMode", "actions": ["needsAttention"] }],
      "Stop": ["needsAttention"],
      "StopFailure": ["needsAttention"],
      "PermissionRequest": ["needsAttention"],
      "Notification": [
        { "matcher": "idle_prompt", "actions": ["needsAttention"] },
        { "matcher": "elicitation_dialog", "actions": ["needsAttention"] }
      ]
    }
  },
  "copilot": {
    "target": "~/.copilot/hooks/wrangler.json",
    "format": "copilot",
    "events": {
      "sessionStart": ["start"],
      "userPromptSubmitted": ["working"],
      "agentStop": ["needsAttention"],
      "errorOccurred": ["needsAttention"],
      "notification": [
        { "matcher": "permission_prompt|elicitation_dialog", "actions": ["needsAttention"] }
      ],
      "sessionEnd": ["end"]
    }
  }
}
